[
  {
    "kind": "_README",
    "description": "Language-agnostic known-answer test (KAT) vectors for the nbus crypto envelope (CRYPTO.md v0.1, FROZEN). Pure data (no code): a runner in ANY language executes each vector against its own crypto impl to prove interop. Signatures are deterministic (ed25519) so exact pub+sig bytes are pinned. Encryption uses random iv/epk, so decrypt/open vectors pin the DECRYPT direction: the recorded envelope + recipient private key must decrypt to the expected plaintext. Skip any entry whose kind starts with '_'. All binary fields are base64url WITHOUT padding (RFC 4648 §5). Generated by tests/gen-crypto-vectors.ts. See tests/crypto-vectors.schema.md.",
    "categories": {
      "jcs": "RFC 8785 JSON Canonicalization: input JSON value -> exact canonical string.",
      "sign": "ed25519 s1 signing: seed+ts+payload -> exact pub, sig, and signingInput bytes.",
      "verify": "s1 verification: envelope+skew+now -> ok/reason (valid, tampered, expired, skew-off).",
      "decrypt": "e1 decryption: recipientPriv+envelope -> plaintext (incl. tampered-ct fail).",
      "open": "sign-then-encrypt: recipientPriv+envelope+skew+now -> signer pub + verified payload."
    }
  },
