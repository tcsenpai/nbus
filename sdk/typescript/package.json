{
  "name": "@nbus/client",
  "version": "0.1.1",
  "description": "TypeScript client SDK for nbus — local IPC bus (pub/sub + shared state) with an optional end-to-end crypto layer. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "tcsenpai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tcsenpai/nbus.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/tcsenpai/nbus/wiki",
  "bugs": {
    "url": "https://github.com/tcsenpai/nbus/issues"
  },
  "keywords": [
    "nbus",
    "ipc",
    "pubsub",
    "bus",
    "unix-socket",
    "ed25519",
    "x25519",
    "crypto"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "bun": ">=1.0.0"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
